{
  "name": "six-second-scribbles-multiplayer",
  "version": "0.1.0",
  "description": "Multiplayer web implementation of Six Second Scribbles party drawing game",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev:web": "vite --debug",
    "dev:server": "partykit dev --live",
    "dev": "concurrently --kill-others --prefix command \"npm:dev:web\" \"npm:dev:server\"",
    "build:web": "vue-tsc --build && vite build",
    "build:server": "partykit build",
    "build": "npm run build:web",
    "deploy:server": "partykit deploy",
    "deploy": "run-s build:web deploy:server",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test": "run-s test:*",
    "type-check": "vue-tsc --build",
    "lint:ox": "oxlint . --warn-on-unfixable --ignore-path .gitignore",
    "lint:es": "eslint . --fix --cache",
    "lint": "run-s lint:ox lint:es",
    "format": "prettier --write . --ignore-path .gitignore"
  },
  "dependencies": {
    "partysocket": "1.1.6",
    "pinia": "^3.0.3",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@prettier/plugin-oxc": "^0.0.4",
    "@tsconfig/node22": "^22.0.2",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^22.18.11",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "@vitest/eslint-plugin": "^1.3.23",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.37.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-oxlint": "~1.23.0",
    "eslint-plugin-playwright": "^2.2.2",
    "eslint-plugin-vue": "~10.5.0",
    "happy-dom": "^20.0.10",
    "jiti": "^2.6.1",
    "jsdom": "^27.2.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.23.0",
    "partykit": "^0.0.115",
    "prettier": "3.6.2",
    "typescript": "~5.9.0",
    "vite": "npm:rolldown-vite@latest",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.1"
  }
}
