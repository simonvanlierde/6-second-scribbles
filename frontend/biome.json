{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"files": {
		"includes": [
			"**",
			"!.astro",
			"!dist",
			"!node_modules",
			"!coverage",
			"!playwright-report",
			"!test-results",
			"!src/generated"
		]
	},
	"vcs": {
		"useIgnoreFile": true
	},
	"formatter": {
		"indentStyle": "space",
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": "on"
		}
	},
	"html": {
		"experimentalFullSupportEnabled": true,
		"formatter": {
			"enabled": true
		}
	}
}
