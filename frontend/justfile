set shell := ["bash", "-euo", "pipefail", "-c"]

# List available recipes.
default:
    @just --list

# ── Dev ───────────────────────────────────────────────────────────────────────

# Start the frontend dev server.
[group('dev')]
dev:
    pnpm run dev

# ── Test ──────────────────────────────────────────────────────────────────────

# Run unit tests.
[group('test')]
test:
    pnpm run test:unit

# Run e2e tests.
[group('test')]
test-e2e:
    pnpm run test:e2e

# Run e2e tests in the Playwright UI.
[group('test')]
test-e2e-ui:
    pnpm run test:e2e:ui

# ── Check & Format ────────────────────────────────────────────────────────────

# Run all checks (lint, type-check).
[group('check')]
check:
    pnpm run lint
    pnpm run type-check

# ── Build ─────────────────────────────────────────────────────────────────────

# Build the frontend for production.
[group('build')]
build:
    pnpm run build

# ── Install ───────────────────────────────────────────────────────────────────

# Install frontend dependencies.
[group('install')]
install:
    pnpm install
