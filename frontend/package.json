{
  "name": "six-second-scribbles-multiplayer",
  "version": "0.2.0",
  "description": "Multiplayer web implementation of Six Second Scribbles party drawing game",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "contracts:generate": "node scripts/generate-contracts.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui --headed",
    "test:e2e:a11y": "playwright test -c playwright.a11y.config.ts",
    "format": "biome check --write .",
    "type-check": "vue-tsc --build",
    "lint": "biome check ."
  },
  "dependencies": {
    "@fontsource/kalam": "^5.2.8",
    "@fontsource/patrick-hand": "^5.2.8",
    "@vueuse/core": "^14.3.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.2",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/node26": "^26.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "json-schema-to-zod": "^2.8.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.6"
  }
}
