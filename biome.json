{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": {
    "includes": [
      "*.js",
      "*.cjs",
      "*.mjs",
      "*.json",
      "*.jsonc",
      "*.yml",
      "*.yaml",
      "*.toml",
      ".github/**",
      "contracts/**",
      "scripts/**"
    ]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "indentStyle": "space",
    "lineWidth": 120
  }
}
