# .env.example - Example environment variables for 6 Second Scribbles backend
# Copy to .env.dev (local development) and .env.prod (production) and update values as needed

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=scribbles_dev

# Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Network Configuration
ALLOWED_ORIGINS=http://localhost:3000