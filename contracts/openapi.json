{
  "components": {
    "schemas": {
      "AppInfoResponse": {
        "description": "Root endpoint response.",
        "properties": {
          "cache": {
            "default": "ok",
            "title": "Cache",
            "type": "string"
          },
          "database": {
            "default": "ok",
            "title": "Database",
            "type": "string"
          },
          "service": {
            "title": "Service",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": ["status", "service", "version"],
        "title": "AppInfoResponse",
        "type": "object"
      },
      "CategoryListItem": {
        "description": "Compact localized category representation used by list endpoints.",
        "properties": {
          "difficulty": {
            "$ref": "#/components/schemas/Difficulty"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "locale": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/LanguageCode"
              },
              {
                "type": "null"
              }
            ]
          },
          "name": {
            "title": "Name",
            "type": "string"
          }
        },
        "required": ["id", "name", "difficulty", "locale"],
        "title": "CategoryListItem",
        "type": "object"
      },
      "CategorySelectionRequest": {
        "description": "Parameters for selecting category sets for a room/game.",
        "properties": {
          "count": {
            "default": 1,
            "minimum": 1.0,
            "title": "Count",
            "type": "integer"
          },
          "difficulty": {
            "$ref": "#/components/schemas/Difficulty"
          },
          "locale": {
            "$ref": "#/components/schemas/LanguageCode",
            "default": "en"
          },
          "locales": {
            "items": {
              "$ref": "#/components/schemas/LanguageCode"
            },
            "title": "Locales",
            "type": "array"
          },
          "player_count": {
            "default": 2,
            "minimum": 1.0,
            "title": "Player Count",
            "type": "integer"
          }
        },
        "required": ["difficulty"],
        "title": "CategorySelectionRequest",
        "type": "object"
      },
      "CategorySelectionResponse": {
        "description": "Response for room-scoped category selection.",
        "properties": {
          "difficulty": {
            "$ref": "#/components/schemas/Difficulty"
          },
          "selections": {
            "items": {
              "$ref": "#/components/schemas/SelectedCategorySet"
            },
            "title": "Selections",
            "type": "array"
          }
        },
        "required": ["difficulty", "selections"],
        "title": "CategorySelectionResponse",
        "type": "object"
      },
      "CreateRoomResponse": {
        "description": "Response for newly created room.",
        "properties": {
          "room_code": {
            "title": "Room Code",
            "type": "string"
          }
        },
        "required": ["room_code"],
        "title": "CreateRoomResponse",
        "type": "object"
      },
      "Difficulty": {
        "enum": ["easy", "medium", "hard"],
        "type": "string"
      },
      "GamePhase": {
        "description": "Valid room lifecycle phases for game flow state.",
        "enum": ["lobby", "drawing", "guessing", "round_results", "final_results"],
        "title": "GamePhase",
        "type": "string"
      },
      "GuessMatchDetailResult": {
        "additionalProperties": false,
        "description": "Detailed scoring information for a matched guess.",
        "properties": {
          "guess": {
            "title": "Guess",
            "type": "string"
          },
          "matched_item": {
            "title": "Matched Item",
            "type": "string"
          },
          "method": {
            "$ref": "#/components/schemas/MatchMethod"
          },
          "similarity": {
            "title": "Similarity",
            "type": "number"
          }
        },
        "required": ["guess", "matched_item", "similarity", "method"],
        "title": "GuessMatchDetailResult",
        "type": "object"
      },
      "GuessScoreRequest": {
        "description": "Request body for scoring player guesses.",
        "properties": {
          "alternatives": {
            "additionalProperties": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "title": "Alternatives",
            "type": "object"
          },
          "correct_answers": {
            "items": {
              "type": "string"
            },
            "title": "Correct Answers",
            "type": "array"
          },
          "guesses": {
            "items": {
              "type": "string"
            },
            "title": "Guesses",
            "type": "array"
          }
        },
        "required": ["guesses", "correct_answers"],
        "title": "GuessScoreRequest",
        "type": "object"
      },
      "GuessScoreResponse": {
        "description": "Response body for scoring player guesses.",
        "properties": {
          "matches": {
            "items": {
              "$ref": "#/components/schemas/GuessMatchDetailResult"
            },
            "title": "Matches",
            "type": "array"
          },
          "percentage": {
            "title": "Percentage",
            "type": "number"
          },
          "score": {
            "title": "Score",
            "type": "integer"
          },
          "total": {
            "title": "Total",
            "type": "integer"
          },
          "unmatched_answers": {
            "items": {
              "type": "string"
            },
            "title": "Unmatched Answers",
            "type": "array"
          }
        },
        "required": ["score", "total", "percentage", "matches", "unmatched_answers"],
        "title": "GuessScoreResponse",
        "type": "object"
      },
      "GuestAuthRequest": {
        "description": "Optional request body for guest session bootstrap.",
        "properties": {
          "displayName": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Displayname"
          },
          "preferredLocale": {
            "default": "en",
            "title": "Preferredlocale",
            "type": "string"
          }
        },
        "title": "GuestAuthRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "LanguageCode": {
        "pattern": "^[a-z]{2,5}$",
        "type": "string"
      },
      "LocaleAvailabilityItem": {
        "description": "Aggregated locale support across selectable system categories.",
        "properties": {
          "category_count": {
            "title": "Category Count",
            "type": "integer"
          },
          "difficulty_counts": {
            "additionalProperties": {
              "type": "integer"
            },
            "title": "Difficulty Counts",
            "type": "object"
          },
          "locale": {
            "$ref": "#/components/schemas/LanguageCode"
          }
        },
        "required": ["locale", "category_count"],
        "title": "LocaleAvailabilityItem",
        "type": "object"
      },
      "LoginRequest": {
        "description": "Request body for username/password login.",
        "properties": {
          "password": {
            "maxLength": 128,
            "minLength": 8,
            "title": "Password",
            "type": "string"
          },
          "username": {
            "maxLength": 40,
            "minLength": 3,
            "pattern": "^[a-zA-Z0-9_-]+$",
            "title": "Username",
            "type": "string"
          }
        },
        "required": ["username", "password"],
        "title": "LoginRequest",
        "type": "object"
      },
      "MatchMethod": {
        "enum": ["exact", "fuzzy", "alternative", "none"],
        "type": "string"
      },
      "QuickPlayResponse": {
        "description": "Response for quick-play: a joinable room, existing or freshly created.",
        "properties": {
          "kind": {
            "enum": ["existing", "created"],
            "title": "Kind",
            "type": "string"
          },
          "room_code": {
            "title": "Room Code",
            "type": "string"
          }
        },
        "required": ["room_code", "kind"],
        "title": "QuickPlayResponse",
        "type": "object"
      },
      "RandomRoomResponse": {
        "description": "Response for finding a random joinable room.",
        "properties": {
          "max_players": {
            "title": "Max Players",
            "type": "integer"
          },
          "player_count": {
            "title": "Player Count",
            "type": "integer"
          },
          "room_code": {
            "title": "Room Code",
            "type": "string"
          }
        },
        "required": ["room_code", "player_count", "max_players"],
        "title": "RandomRoomResponse",
        "type": "object"
      },
      "RegisterRequest": {
        "description": "Request body for account registration.",
        "properties": {
          "displayName": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Displayname"
          },
          "password": {
            "maxLength": 128,
            "minLength": 8,
            "title": "Password",
            "type": "string"
          },
          "preferredLocale": {
            "default": "en",
            "title": "Preferredlocale",
            "type": "string"
          },
          "username": {
            "maxLength": 40,
            "minLength": 3,
            "pattern": "^[a-zA-Z0-9_-]+$",
            "title": "Username",
            "type": "string"
          }
        },
        "required": ["username", "password"],
        "title": "RegisterRequest",
        "type": "object"
      },
      "RoomStatusResponse": {
        "description": "Response for room status checks.",
        "properties": {
          "exists": {
            "title": "Exists",
            "type": "boolean"
          },
          "game_phase": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/GamePhase"
              },
              {
                "type": "null"
              }
            ]
          },
          "players": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Players"
          }
        },
        "required": ["exists"],
        "title": "RoomStatusResponse",
        "type": "object"
      },
      "SelectedCategorySet": {
        "description": "One selected localized category set for game setup.",
        "properties": {
          "alternatives": {
            "additionalProperties": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "title": "Alternatives",
            "type": "object"
          },
          "category_id": {
            "title": "Category Id",
            "type": "integer"
          },
          "category_name": {
            "title": "Category Name",
            "type": "string"
          },
          "item_ids": {
            "items": {
              "type": "integer"
            },
            "title": "Item Ids",
            "type": "array"
          },
          "items": {
            "items": {
              "type": "string"
            },
            "title": "Items",
            "type": "array"
          }
        },
        "required": ["category_id", "category_name", "item_ids", "items", "alternatives"],
        "title": "SelectedCategorySet",
        "type": "object"
      },
      "StatsResponse": {
        "description": "Server statistics response.",
        "properties": {
          "active_rooms": {
            "title": "Active Rooms",
            "type": "integer"
          },
          "empty_rooms": {
            "title": "Empty Rooms",
            "type": "integer"
          },
          "hibernated_rooms": {
            "title": "Hibernated Rooms",
            "type": "integer"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "total_players": {
            "title": "Total Players",
            "type": "integer"
          },
          "total_rooms": {
            "title": "Total Rooms",
            "type": "integer"
          }
        },
        "required": ["status", "total_rooms", "active_rooms", "hibernated_rooms", "empty_rooms", "total_players"],
        "title": "StatsResponse",
        "type": "object"
      },
      "UpdatePreferencesRequest": {
        "description": "Request body for updating user preferences.",
        "properties": {
          "displayName": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Displayname"
          },
          "preferredLocale": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Preferredlocale"
          }
        },
        "title": "UpdatePreferencesRequest",
        "type": "object"
      },
      "UserResponse": {
        "description": "Public user payload for the current authenticated session.",
        "properties": {
          "displayName": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Displayname"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "isGuest": {
            "title": "Isguest",
            "type": "boolean"
          },
          "preferredLocale": {
            "title": "Preferredlocale",
            "type": "string"
          },
          "username": {
            "title": "Username",
            "type": "string"
          }
        },
        "required": ["id", "username", "displayName", "preferredLocale", "isGuest"],
        "title": "UserResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": ["loc", "msg", "type"],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Real-time multiplayer drawing game backend",
    "title": "Six Second Scribbles API",
    "version": "2.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/auth/guest": {
      "post": {
        "description": "Create a guest user and authenticated session.",
        "operationId": "create_guest_auth_session_api_auth_guest_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GuestAuthRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Guest Auth Session",
        "tags": ["auth"]
      }
    },
    "/api/auth/login": {
      "post": {
        "description": "Authenticate an existing user and start a new session.",
        "operationId": "login_api_auth_login_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Login",
        "tags": ["auth"]
      }
    },
    "/api/auth/logout": {
      "post": {
        "description": "Logout the current session.",
        "operationId": "logout_api_auth_logout_post",
        "parameters": [
          {
            "in": "cookie",
            "name": "scribbles_session",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Scribbles Session"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Logout",
        "tags": ["auth"]
      }
    },
    "/api/auth/register": {
      "post": {
        "description": "Register a new account or claim the current guest user.",
        "operationId": "register_api_auth_register_post",
        "parameters": [
          {
            "in": "cookie",
            "name": "scribbles_session",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Scribbles Session"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Register",
        "tags": ["auth"]
      }
    },
    "/api/categories": {
      "get": {
        "description": "Get all categories, optionally filtered by difficulty and language.",
        "operationId": "get_categories_api_categories_get",
        "parameters": [
          {
            "in": "query",
            "name": "difficulty",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/Difficulty"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Difficulty"
            }
          },
          {
            "in": "query",
            "name": "language",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/LanguageCode"
                },
                {
                  "type": "null"
                }
              ],
              "default": "en",
              "title": "Language"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/CategoryListItem"
                  },
                  "title": "Response Get Categories Api Categories Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Categories",
        "tags": ["categories"]
      }
    },
    "/api/categories/locales": {
      "get": {
        "description": "Get supported locales with category coverage counts.",
        "operationId": "get_category_locale_availability_api_categories_locales_get",
        "parameters": [
          {
            "in": "query",
            "name": "difficulty",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/Difficulty"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Difficulty"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/LocaleAvailabilityItem"
                  },
                  "title": "Response Get Category Locale Availability Api Categories Locales Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Category Locale Availability",
        "tags": ["categories"]
      }
    },
    "/api/health": {
      "get": {
        "description": "Health check endpoint including Redis and database connectivity.",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppInfoResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health",
        "tags": ["system"]
      }
    },
    "/api/me": {
      "get": {
        "description": "Return the current authenticated user.",
        "operationId": "get_me_api_me_get",
        "parameters": [
          {
            "in": "cookie",
            "name": "scribbles_session",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Scribbles Session"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Me",
        "tags": ["users"]
      }
    },
    "/api/me/preferences": {
      "patch": {
        "description": "Update the current user's basic profile preferences.",
        "operationId": "update_preferences_api_me_preferences_patch",
        "parameters": [
          {
            "in": "cookie",
            "name": "scribbles_session",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Scribbles Session"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePreferencesRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Update Preferences",
        "tags": ["users"]
      }
    },
    "/api/rooms/": {
      "post": {
