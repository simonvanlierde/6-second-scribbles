{
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "room_state",
      "title": "Type",
      "type": "string"
    },
    "players": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "title": "Id",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "color": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Color"
          },
          "connected": {
            "default": true,
            "title": "Connected",
            "type": "boolean"
          },
          "categories": {
            "items": {
              "type": "string"
            },
            "title": "Categories",
            "type": "array"
          }
        },
        "required": ["id", "name"],
        "title": "PlayerSnapshot",
        "type": "object"
      },
      "title": "Players",
      "type": "array"
    },
    "hostId": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Hostid"
    },
    "categories": {
      "items": {
        "type": "string"
      },
      "title": "Categories",
      "type": "array"
    },
    "gamePhase": {
      "description": "Valid room lifecycle phases for game flow state.",
      "enum": ["lobby", "drawing", "guessing", "round_results", "final_results"],
      "title": "GamePhase",
      "type": "string"
    },
    "difficulty": {
      "enum": ["easy", "medium", "hard"],
      "type": "string"
    },
    "currentRound": {
      "default": 0,
      "title": "Currentround",
      "type": "integer"
    },
    "maxRounds": {
      "title": "Maxrounds",
      "type": "integer"
    },
    "roundStartTime": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Roundstarttime"
    },
    "guessingStartTime": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Guessingstarttime"
    },
    "drawingTimeLimit": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "guessingTimeLimit": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "guessTargets": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Guesstargets",
      "type": "object"
    },
    "drawings": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Drawings",
      "type": "object"
    },
    "drawingHistory": {
      "items": {
        "additionalProperties": false,
        "description": "One completed drawing retained for the end-of-game gallery.",
        "properties": {
          "round": {
            "title": "Round",
            "type": "integer"
          },
          "playerId": {
            "title": "Playerid",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "color": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Color"
          },
          "drawing": {
            "title": "Drawing",
            "type": "string"
          }
        },
        "required": ["drawing", "name", "playerId", "round"],
        "title": "GalleryDrawingPayload",
        "type": "object"
      },
      "title": "Drawinghistory",
      "type": "array"
    },
    "card": {
      "anyOf": [
        {
          "properties": {
            "categoryId": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Categoryid"
            },
            "category": {
              "title": "Category",
              "type": "string"
            },
            "itemIds": {
              "anyOf": [
                {
                  "items": {
                    "type": "integer"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Itemids"
            },
            "items": {
              "items": {
                "type": "string"
              },
              "title": "Items",
              "type": "array"
            },
            "alternatives": {
              "anyOf": [
                {
                  "additionalProperties": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "type": "object"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Alternatives"
            }
          },
          "required": ["category", "items"],
          "title": "PlayerCardPayload",
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "readyCount": {
      "default": 0,
      "title": "Readycount",
      "type": "integer"
    },
    "totalPlayers": {
      "default": 0,
      "title": "Totalplayers",
      "type": "integer"
    },
    "padVisibility": {
      "title": "Padvisibility",
      "type": "boolean"
    },
    "isPrivate": {
      "title": "Isprivate",
      "type": "boolean"
    },
    "defaultLocale": {
      "pattern": "^[a-z]{2,5}(?:-[A-Za-z0-9]{2,8})?$",
      "type": "string"
    },
    "customCategoryIds": {
      "anyOf": [
        {
          "items": {
            "type": "integer"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Customcategoryids"
    }
  },
  "required": [
    "defaultLocale",
    "difficulty",
    "gamePhase",
    "isPrivate",
    "maxRounds",
    "padVisibility",
    "players",
    "type"
  ],
  "title": "RoomStateEvent",
  "type": "object"
}
