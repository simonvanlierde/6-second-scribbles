                  },
                  "y": {
                    "title": "Y",
                    "type": "number"
                  }
                },
                "required": ["x", "y"],
                "title": "StrokePoint",
                "type": "object"
              },
              "maxItems": 1000,
              "title": "Points",
              "type": "array"
            }
          },
          "required": ["color", "width"],
          "title": "StrokeDelta",
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null
